# =============================================================================
# M3Motors — Variables de Entorno (raiz)
# =============================================================================
# Copia este archivo como .env en backend/ y completa los valores.
#   cp .env.example backend/.env
#
# En produccion, el deploy workflow construye el .env desde GitHub Secrets.
#
# GitHub Secrets necesarios:
#   DATABASE_URL, DIRECT_URL,
#   CLERK_SECRET_KEY, CLERK_ISSUER_URL, CLERK_WEBHOOK_SECRET,
#   JWT_SECRET, JWT_EXPIRES_IN,
#   GEMINI_API_KEY, GROQ_API_KEY,
#   RESEND_API_KEY, RESEND_FROM_EMAIL,
#   ONESIGNAL_APP_ID, ONESIGNAL_REST_API_KEY,
#   REDIS_HOST, REDIS_PORT, LOG_LEVEL, CORS_ORIGIN,
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_STORAGE_BUCKET,
#   RECAPTCHA_SECRET, QR_BASE_URL,
#   DOCKERHUB_USERNAME, DOCKERHUB_TOKEN, DO_HOST, DO_USERNAME, DO_SSH_KEY,
#   VITE_CLERK_PUBLISHABLE_KEY, VITE_API_URL, VITE_RECAPTCHA_SITE_KEY,
#   EXPO_PUBLIC_API_URL, EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY

# ---------------------------------------------------------------------------
# SERVIDOR
# ---------------------------------------------------------------------------
APP_PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------------------
# BASE DE DATOS — SUPABASE
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/m3motors?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/m3motors?schema=public"

# ---------------------------------------------------------------------------
# SUPABASE — Storage y servicios
# ---------------------------------------------------------------------------
SUPABASE_URL="https://[PROJECT_ID].supabase.co"
SUPABASE_ANON_KEY=tu_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=m3motors-photos

# ---------------------------------------------------------------------------
# AUTENTICACION — CLERK
# Clerk Dashboard > API Keys
# ---------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_tu_clerk_secret_key
CLERK_ISSUER_URL=https://clerk.tudominio.com
CLERK_WEBHOOK_SECRET=whsec_tu_webhook_signing_secret

# ---------------------------------------------------------------------------
# AUTENTICACION (JWT) — Legacy
# ---------------------------------------------------------------------------
JWT_SECRET=changeme_super_secret_key
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# LLM — Gemini / Groq
# ---------------------------------------------------------------------------
GEMINI_API_KEY=tu_gemini_api_key
GROQ_API_KEY=tu_groq_api_key

# ---------------------------------------------------------------------------
# NOTIFICACIONES — RESEND (Email)
# https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=tu_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# ---------------------------------------------------------------------------
# NOTIFICACIONES — ONESIGNAL (Push Notifications)
# https://onesignal.com > Settings > Keys & IDs
# ---------------------------------------------------------------------------
ONESIGNAL_APP_ID=tu_onesignal_app_id
ONESIGNAL_REST_API_KEY=tu_onesignal_rest_api_key

# ---------------------------------------------------------------------------
# NOTIFICACIONES — REDIS
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# RECAPTCHA (Server-side verification)
# Google reCAPTCHA Console > Settings > Secret Key
# ---------------------------------------------------------------------------
RECAPTCHA_SECRET=tu_recaptcha_secret_key

# ---------------------------------------------------------------------------
# QR CODES
# ---------------------------------------------------------------------------
QR_BASE_URL=https://tudominio.com/vehicle

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# CORS
# Desarrollo: http://localhost:5173
# Produccion: https://tudominio.com
# ---------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# =============================================================================
# FRONTEND WEB — Variables de Entorno (Vite)
# =============================================================================
# Copia frontend/web/.env.example a frontend/web/.env

# URL base de la API del backend
# Desarrollo: http://localhost:3000
# Produccion: https://tudominio.com/api
VITE_API_URL=http://localhost:3000

# Modo de ejecucion: development | production
VITE_NODE_ENV=development

# Clerk Dashboard > API Keys > Publishable Key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_tu_clerk_publishable_key

# Google reCAPTCHA Console > Site Key
VITE_RECAPTCHA_SITE_KEY=tu_recaptcha_site_key

# =============================================================================
# FRONTEND MOBILE — Variables de Entorno (Expo)
# =============================================================================
# Copia frontend/mobile/.env.example a frontend/mobile/.env

# URL base de la API del backend
# Desarrollo: http://localhost:3000
# Produccion: https://tudominio.com/api
EXPO_PUBLIC_API_URL=http://localhost:3000

# Clerk Dashboard > API Keys > Publishable Key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_tu_clerk_publishable_key

# OneSignal App ID (push notifications)
ONESIGNAL_APP_ID=tu_onesignal_app_id
