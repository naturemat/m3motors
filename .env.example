# =============================================================================
# M3Motors — Variables de Entorno (raiz)
# =============================================================================
# Copia este archivo como .env en backend/ y completa los valores.
#   cp .env.example backend/.env
#
# En produccion, el deploy workflow construye el .env desde GitHub Secrets.

# ---------------------------------------------------------------------------
# SERVIDOR
# ---------------------------------------------------------------------------
APP_PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------------------
# BASE DE DATOS
# ---------------------------------------------------------------------------
# Desarrollo local (Docker): postgresql://postgres:postgres@localhost:5432/m3motors?schema=public
# Produccion (Supabase):     postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/m3motors?schema=public"

# ---------------------------------------------------------------------------
# AUTENTICACION (JWT)
# ---------------------------------------------------------------------------
# En produccion generar con: openssl rand -hex 32
JWT_SECRET=changeme_super_secret_key
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# TELEGRAM BOT
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui
TELEGRAM_BOT_USERNAME=m3motors_bot

# ---------------------------------------------------------------------------
# LLM (OpenAI / Gemini)
# ---------------------------------------------------------------------------
LLM_API_KEY=sk-your-api-key-placeholder
LLM_MODEL=gpt-4

# ---------------------------------------------------------------------------
# GEMINI OCR — Reconocimiento de placas vehiculares
# https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ---------------------------------------------------------------------------
# GROQ — Inferencia de especificaciones del motor
# https://console.groq.com
# ---------------------------------------------------------------------------
GROQ_API_KEY=tu_groq_api_key_aqui

# ---------------------------------------------------------------------------
# NOTIFICACIONES — RESEND (Email)
# https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=tu_resend_api_key_aqui
RESEND_FROM_EMAIL=onboarding@resend.dev

# ---------------------------------------------------------------------------
# NOTIFICACIONES — ONESIGNAL (Push Notifications)
# https://onesignal.com > Settings > Keys & IDs
# ---------------------------------------------------------------------------
ONESIGNAL_APP_ID=tu_onesignal_app_id
ONESIGNAL_REST_API_KEY=tu_onesignal_rest_api_key

# ---------------------------------------------------------------------------
# NOTIFICACIONES — REDIS (Cola Asincrona)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# NOTIFICACIONES — CONFIGURACION GENERAL
# ---------------------------------------------------------------------------
NOTIFICATION_ENABLED=true
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=5000

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Desarrollo: http://localhost:5173
# Produccion: https://tudominio.com
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# MCP — MODEL CONTEXT PROTOCOL
# ---------------------------------------------------------------------------
MCP_SERVER_URL=http://localhost:8080/mcp
