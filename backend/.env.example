# =============================================================================
# M3Motors — Backend: Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores segun tu entorno.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# SERVIDOR
# ---------------------------------------------------------------------------
APP_PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------------------
# BASE DE DATOS — SUPABASE
# ---------------------------------------------------------------------------
# Pooler de transacciones (para la aplicación)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]-pooler.supabase.co:6543/postgres?pgbouncer=true"

# Pooler de sesiones (para migraciones de Prisma)
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]-pooler.supabase.co:5432/postgres"

# ---------------------------------------------------------------------------
# SUPABASE — Storage y servicios
# ---------------------------------------------------------------------------
SUPABASE_URL="https://[PROJECT_ID].supabase.co"
SUPABASE_ANON_KEY=tu_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=m3motors-photos

# ---------------------------------------------------------------------------
# AUTENTICACION — CLERK
# Clerk Dashboard > API Keys
# ---------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_tu_clerk_secret_key
CLERK_ISSUER_URL=https://clerk.tudominio.com
CLERK_WEBHOOK_SECRET=whsec_tu_webhook_signing_secret

# ---------------------------------------------------------------------------
# AUTENTICACION (JWT) — Legacy
# ---------------------------------------------------------------------------
JWT_SECRET=changeme_super_secret_key
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# LLM — Gemini / Groq
# ---------------------------------------------------------------------------
GEMINI_API_KEY=tu_gemini_api_key
GROQ_API_KEY=tu_groq_api_key
LLM_API_KEY=sk-your-api-key-placeholder
LLM_MODEL=gpt-4

# ---------------------------------------------------------------------------
# NOTIFICACIONES — RESEND (Email)
# https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=tu_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# ---------------------------------------------------------------------------
# NOTIFICACIONES — ONESIGNAL (Push Notifications)
# https://onesignal.com > Settings > Keys & IDs
# ---------------------------------------------------------------------------
ONESIGNAL_APP_ID=tu_onesignal_app_id
ONESIGNAL_REST_API_KEY=tu_onesignal_rest_api_key

# ---------------------------------------------------------------------------
# NOTIFICACIONES — REDIS
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
NOTIFICATION_ENABLED=true
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=5000

# ---------------------------------------------------------------------------
# MCP — MODEL CONTEXT PROTOCOL
# ---------------------------------------------------------------------------
MCP_SERVER_URL=http://localhost:8080/mcp

# ---------------------------------------------------------------------------
# RECAPTCHA (Server-side verification)
# Google reCAPTCHA Console > Settings > Secret Key
# ---------------------------------------------------------------------------
RECAPTCHA_SECRET=tu_recaptcha_secret_key

# ---------------------------------------------------------------------------
# QR CODES
# ---------------------------------------------------------------------------
QR_BASE_URL=https://tudominio.com/vehicle

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# CORS
# Desarrollo: http://localhost:5173
# Produccion: https://tudominio.com
# ---------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173
