# =============================================================================
# M3Motors — Backend: Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores según tu entorno.
#   cp backend/.env.example backend/.env

# ---------------------------------------------------------------------------
# SERVIDOR
# ---------------------------------------------------------------------------

# Puerto en el que se ejecuta la aplicación NestJS
# Desarrollo: 3000 | Producción: el que asigne el proveedor cloud
APP_PORT=3000

# Entorno de ejecución: development | test | production
NODE_ENV=development

# ---------------------------------------------------------------------------
# BASE DE DATOS
# ---------------------------------------------------------------------------

# URL de conexión a PostgreSQL
# Formato: postgresql://USUARIO:CONTRASENA@HOST:PUERTO/NOMBRE_BD
#
# Opción 1 — Desarrollo local (Docker):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/m3motors?schema=public"
#
# Opción 2 — Supabase (producción/staging):
# DATABASE_URL="postgresql://postgres:[TU_PASSWORD]@[TU_HOST].supabase.co:5432/postgres"

# ---------------------------------------------------------------------------
# AUTENTICACIÓN (JWT)
# ---------------------------------------------------------------------------

# Clave secreta para firmar y verificar tokens JWT
# En producción, usar una clave fuerte generada con: openssl rand -hex 32
JWT_SECRET=changeme_super_secret_jwt_key_2024

# Tiempo de expiración del token JWT (formato: https://github.com/vercel/ms)
# Valores recomendados: 7d (7 días), 1d (1 día), 8h (8 horas)
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# TELEGRAM BOT
# ---------------------------------------------------------------------------

# Token del bot de Telegram para notificaciones al taller
# Obtenlo de: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui

# Nombre de usuario del bot (opcional, para enlaces directos)
TELEGRAM_BOT_USERNAME=m3motors_bot

# ---------------------------------------------------------------------------
# MCP — MODEL CONTEXT PROTOCOL
# ---------------------------------------------------------------------------

# URL del servidor MCP para comunicación con herramientas externas
MCP_SERVER_URL=http://localhost:8080/mcp

# ---------------------------------------------------------------------------
# LLM — OPENAI / GEMINI
# ---------------------------------------------------------------------------

# API Key del proveedor de LLM (OpenAI, Google Gemini, etc.)
# En desarrollo puedes usar un placeholder; en producción usar secrets reales
LLM_API_KEY=sk-your-api-key-placeholder

# Modelo de LLM a utilizar
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Gemini: gemini-pro, gemini-1.5-pro
LLM_MODEL=gpt-4

# ---------------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------------

# Nivel de registro: debug | info | warn | error
# Desarrollo: debug | Producción: warn
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Origen(es) permitido(s) para CORS (separados por coma si son varios)
# Desarrollo: http://localhost:5173 (puerto de Vite)
# Producción: https://tudominio.com
CORS_ORIGIN=http://localhost:5173
