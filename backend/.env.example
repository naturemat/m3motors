# =============================================================================
# M3Motors — Backend: Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores segun tu entorno.
#   cp .env.example backend/.env
#
# Consulta el .env.example en la raiz del repo para la referencia completa.

# Puerto del backend NestJS
APP_PORT=3000

# Modo: development | test | production
NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/m3motors?schema=public"

# JWT
JWT_SECRET=changeme_super_secret_key
JWT_EXPIRES_IN=7d

# Telegram
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui
TELEGRAM_BOT_USERNAME=m3motors_bot

# LLM
LLM_API_KEY=sk-your-api-key-placeholder
LLM_MODEL=gpt-4

# Gemini OCR
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Groq
# Copia este archivo como .env y completa los valores según tu entorno.
#   cp backend/.env.example backend/.env

# ---------------------------------------------------------------------------
# BASE DE DATOS (Supabase PostgreSQL)
# ---------------------------------------------------------------------------

# Pooler de transacciones (para la aplicación)
DATABASE_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Pooler de sesiones (para migraciones de Prisma)
DIRECT_URL="postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# SUPABASE
# ---------------------------------------------------------------------------

# URL del proyecto Supabase
SUPABASE_URL="https://[PROJECT_ID].supabase.co"

# Anon key (pública, para clientes)
SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui

# Service role key (privada, solo backend)
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key_aqui

# ---------------------------------------------------------------------------
# SERVIDOR
# ---------------------------------------------------------------------------

APP_PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------------------
# AUTENTICACIÓN (JWT — temporal hasta integrar Clerk)
# ---------------------------------------------------------------------------

JWT_SECRET=changeme_super_secret_jwt_key_2024
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# TELEGRAM BOT
# ---------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui
TELEGRAM_BOT_USERNAME=m3motors_bot

# ---------------------------------------------------------------------------
# MCP — MODEL CONTEXT PROTOCOL
# ---------------------------------------------------------------------------

MCP_SERVER_URL=http://localhost:8080/mcp

# ---------------------------------------------------------------------------
# GEMINI OCR — Reconocimiento de placas vehiculares
# ---------------------------------------------------------------------------

GEMINI_API_KEY=tu_gemini_api_key_aqui

# ---------------------------------------------------------------------------
# GROQ — Inferencia de especificaciones del motor
# ---------------------------------------------------------------------------

GROQ_API_KEY=tu_groq_api_key_aqui

# Resend (Email)
RESEND_API_KEY=tu_resend_api_key_aqui
RESEND_FROM_EMAIL=onboarding@resend.dev

# OneSignal (Push)
ONESIGNAL_APP_ID=tu_onesignal_app_id
ONESIGNAL_REST_API_KEY=tu_onesignal_rest_api_key

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Notificaciones
NOTIFICATION_ENABLED=true
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=5000

# Logging
LOG_LEVEL=debug

# CORS
# ---------------------------------------------------------------------------

CORS_ORIGIN=http://localhost:5173

# MCP
MCP_SERVER_URL=http://localhost:8080/mcp
