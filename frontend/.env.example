# =============================================================================
# M3Motors — Frontend: Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores según tu entorno.
#   cp frontend/.env.example frontend/.env
#
# Todas las variables deben comenzar con VITE_ para ser expuestas al
# cliente por Vite. Ver: https://vitejs.dev/guide/env-and-mode

# ---------------------------------------------------------------------------
# API BACKEND
# ---------------------------------------------------------------------------

# URL base de la API del backend NestJS
# Desarrollo: http://localhost:3000
# Producción: https://api.m3motors.com
VITE_API_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# ENTORNO
# ---------------------------------------------------------------------------

# Modo de ejecución: development | production
# Vite lo usa internamente; también puedes usarlo en tu código con
# import.meta.env.VITE_NODE_ENV
VITE_NODE_ENV=development

# ---------------------------------------------------------------------------
# AUTENTICACIÓN (opcional — para integración futura)
# ---------------------------------------------------------------------------

# Dominio del proveedor de autenticación (Auth0, Clerk, etc.)
# Se usará para redirecciones OAuth en el frontend
VITE_AUTH_DOMAIN=

# Identificador del cliente de autenticación
VITE_AUTH_CLIENT_ID=

# ---------------------------------------------------------------------------
# TELEGRAM (opcional)
# ---------------------------------------------------------------------------

# Nombre de usuario del bot de Telegram (para enlaces directos
# desde el dashboard al chat del taller)
VITE_TELEGRAM_BOT_USERNAME=m3motors_bot
