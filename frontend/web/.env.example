# =============================================================================
# M3Motors — Frontend: Variables de Entorno
# =============================================================================
# Copia este archivo como .env y completa los valores segun tu entorno.
#   cp frontend/.env.example frontend/.env
#
# Todas las variables deben comenzar con VITE_ para ser expuestas al
# cliente por Vite. Ver: https://vitejs.dev/guide/env-and-mode

# ---------------------------------------------------------------------------
# API BACKEND
# ---------------------------------------------------------------------------

# URL base de la API del backend NestJS
# Desarrollo: http://localhost:3000
# Produccion: https://api.m3motors.com
VITE_API_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# ENTORNO
# ---------------------------------------------------------------------------

# Modo de ejecucion: development | production
VITE_NODE_ENV=development

# ---------------------------------------------------------------------------
# AUTENTICACION (Clerk)
# ---------------------------------------------------------------------------

# Clerk Dashboard > API Keys > Publishable Key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_tu_clerk_publishable_key

# ---------------------------------------------------------------------------
# RECAPTCHA
# ---------------------------------------------------------------------------

# Google reCAPTCHA Console > Site Key
VITE_RECAPTCHA_SITE_KEY=tu_recaptcha_site_key
