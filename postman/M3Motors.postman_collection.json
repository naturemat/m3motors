            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Obtiene el perfil del usuario autenticado con Clerk. Retorna role, workshopId, etc."
          },
          "response": []
        }
      ]
    },
